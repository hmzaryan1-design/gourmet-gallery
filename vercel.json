{
  "rewrites": [
    { 
      "source": "/((?!sitemap.xml|robots.txt|favicon.png|assets/.*).*)", 
      "destination": "/index.html" 
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ]
}
